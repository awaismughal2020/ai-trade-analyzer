# Coin Market Analyzer - Environment Configuration

# =============================================================================
# Environment Mode
# =============================================================================
# Set to "development" for port 8900, "production" for port 8000
ENVIRONMENT=production

# =============================================================================
# API Configuration
# =============================================================================

# Internal API (for data fetching)
INTERNAL_API_BASE_URL=http://52.3.148.51:3000

# Meme Token API
MEME_API_BASE_URL=http://52.3.148.51:3000

# Perps API
PERPS_API_BASE_URL=http://52.3.148.51:3000

# Birdeye API (for Solana tokens)
BIRDEYE_API_KEY=your_birdeye_api_key_here
BIRDEYE_CHAIN=solana
BIRDEYE_RATE_LIMIT=15

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Maximum concurrent API connections
MAX_CONCURRENT_REQUESTS=15

# Target requests per second
REQUESTS_PER_SECOND=50

# Minimum interval between requests (in seconds)
MIN_REQUEST_INTERVAL=0.05

# Delay between batches (in seconds)
BATCH_DELAY=0.1

# =============================================================================
# OpenAI Configuration
# =============================================================================

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# =============================================================================
# Layer Weights (0.0 - 1.0, should sum to 1.0)
# =============================================================================

LAYER_WEIGHT_ML=0.30
LAYER_WEIGHT_WHALE=0.25
LAYER_WEIGHT_TECHNICAL=0.10
LAYER_WEIGHT_HOLDER=0.15
LAYER_WEIGHT_USER=0.20

# =============================================================================
# Server Configuration
# =============================================================================

HOST=0.0.0.0
# Port is determined by ENVIRONMENT:
# - production: 8000
# - development: 8900
APP_PORT=8000
